{
  "manifest_version": 3,
  "name": "Ai Extractor",
  "version": "1.0.0",
  "description": "Extrator estruturado de vagas para IA",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "options_page": "src/options/index.html",
  "host_permissions": [
    "*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ]
}